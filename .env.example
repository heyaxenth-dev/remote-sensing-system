# Copy to `.env` for local Expo / tooling (never commit real secrets).

# Supabase (required by the mobile app — see README)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Admin web app (`admin/`, Vite): use the same Supabase project as above.
# Copy URL and anon key into `admin/.env` (Vite only exposes `VITE_*`).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: Python FastAPI analyzer (`npm run analyze-server`). When unset, the app uses on-device heuristics.
EXPO_PUBLIC_ANALYZE_API_URL=http://127.0.0.1:8000

# Weather: Open-Meteo is free and needs no API key. Override only if you proxy or self-host.
# Expo (dashboard + local recommendation enrichment):
EXPO_PUBLIC_OPEN_METEO_FORECAST_URL=https://api.open-meteo.com/v1/forecast
# Python analyzer (`analysis/recommend.py`):
OPEN_METEO_FORECAST_URL=https://api.open-meteo.com/v1/forecast

# Optional: seed script / admin
SUPABASE_SERVICE_ROLE_KEY=
